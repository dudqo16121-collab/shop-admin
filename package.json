{
  "name": "shop-admin",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && set NODE_ENV=development && npx electron .\"",
    "electron:build": "next build && electron-builder"
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.shopadmin.app",
    "productName": "ShopAdmin",
    "directories": {
      "output": "dist"
    },
"win": {
  "target": "nsis"
},
"mac": {
  "target": "dmg"
},
    "files": [
      "out/**",
      "electron.js"
    ]
  }
}